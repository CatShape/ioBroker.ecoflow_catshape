{
    "i18n": false,
    "type": "panel",
    "items": {
        "cumulateDailyResetTime": {
            "type": "text",
            "label": "cumulateDailyResetTime",
            "newLine": true,
            "sm": 12,
            "md": 6,
            "lg": 4
        },
        "_introTableScheduleRules": {
            "type": "staticText",
            "text": "Please add one entry for each of the desired schedule rules.",
            "newLine": true
        },
        "scheduleRules": {
            "sm": 12,
            "newLine": true,
            "type": "table",
            "items": [
                {
                    "type": "text",
                    "attr": "scheduleRule",
                    "width": "100%",
                    "title": "Schedule rule",
                    "filter": false,
                    "sort": false,
                    "default": "{second: [3, 15, 27, 39, 51]}"
                }
            ]
        },
        "_introTableDevices": {
            "type": "staticText",
            "text": "Please add one entry for each of your Ecoflow devices.",
            "newLine": true
        },
        "devices": {
            "sm": 12,
            "newLine": true,
            "type": "table",
            "items": [
                {
                    "type": "text",
                    "attr": "serialNumber",
                    "width": "20%",
                    "title": "Serial number",
                    "filter": false,
                    "sort": false,
                    "default": "xxxxx"
                },
                {
                    "type": "text",
                    "attr": "apiAccessKey",
                    "width": "35%",
                    "title": "API access key",
                    "filter": false,
                    "sort": false,
                    "default": ""
                },
                {
                    "type": "password",
                    "attr": "apiSecretKey",
                    "width": "35%",
                    "title": "API secret key",
                    "filter": false,
                    "sort": false,
                    "default": ""
                },
                {
                    "type": "checkbox",
                    "attr": "doNotUpdateOffline",
                    "title": "Do not update the states if device is offline",
                    "width": "5%",
                    "filter": false,
                    "sort": false,
                    "default": true
                },
                {
                    "type": "checkbox",
                    "attr": "updateQuotaState",
                    "title": "Update quota state",
                    "width": "5%",
                    "filter": false,
                    "sort": false,
                    "default": false
                }
            ]
        }
    }
}
