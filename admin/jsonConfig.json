{
    "i18n": false,
    "type": "panel",
    "items": {
        "cronSchedule": {
            "type": "text",
            "label": "node-cron schedule for getting data from EcoFlow",
            "newLine": true,
            "sm": 12,
            "md": 6,
            "lg": 4
        },
        "cumulateDailyResetTime": {
            "type": "text",
            "label": "Reset time for cumulate daily states (state gets set to 0)",
            "newLine": true,
            "sm": 12,
            "md": 6,
            "lg": 4
        },
        "_introTableApiKeys": {
            "type": "staticText",
            "text": "Please add one entry for each of your Ecoflow API keys.",
            "newLine": true
        },
        "apiKeys": {
            "sm": 12,
            "newLine": true,
            "type": "table",
            "items": [
                {
                    "type": "text",
                    "attr": "accessKey",
                    "width": "50%",
                    "title": "API access key",
                    "filter": false,
                    "sort": false,
                    "default": ""
                },
                {
                    "type": "password",
                    "attr": "secretKey",
                    "width": "50%",
                    "title": "API secret key",
                    "filter": false,
                    "sort": false,
                    "default": ""
                }
            ]
        },
        "_introTableDevices": {
            "type": "staticText",
            "text": "Please add one entry for each of your EcoFlow devices.",
            "newLine": true
        },
        "devices": {
            "sm": 12,
            "newLine": true,
            "type": "table",
            "items": [
                {
                    "type": "text",
                    "attr": "serialNumber",
                    "width": "50%",
                    "title": "Serial number",
                    "filter": false,
                    "sort": false,
                    "default": ""
                },
                {
                    "type": "select",
                    "attr": "apiKey",
                    "width": "15%",
                    "options": [
                        { "value": "1", "label": "1." },
                        { "value": "2", "label": "2." },
                        { "value": "3", "label": "3." },
                        { "value": "4", "label": "4." },
                        { "value": "5", "label": "5." },
                        { "value": "6", "label": "6." },
                        { "value": "7", "label": "7." },
                        { "value": "8", "label": "8." },
                        { "value": "9", "label": "9." }
                    ],
                    "title": "API key to use",
                    "filter": false,
                    "sort": false,
                    "default": 1
                },
                {
                    "type": "checkbox",
                    "attr": "doNotUpdateOffline",
                    "title": "Do not update the states if device is offline",
                    "width": "10%",
                    "filter": false,
                    "sort": false,
                    "default": true
                },
                {
                    "type": "checkbox",
                    "attr": "updateQuotaState",
                    "title": "Update quota state",
                    "width": "10%",
                    "filter": false,
                    "sort": false,
                    "default": false
                }
            ]
        }
    }
}
